{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Information about the registered user.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique user ID from Firebase Auth." },
        "email": { "type": "string", "format": "email", "description": "User's email address." },
        "displayName": { "type": "string", "description": "User's display name." },
        "photoURL": { "type": "string", "description": "URL to user's profile picture." }
      },
      "required": ["uid", "email"]
    },
    "GameEntry": {
      "title": "Game Entry",
      "description": "A saved game or private server link.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the game or server." },
        "link": { "type": "string", "format": "uri", "description": "URL link to the game or server." },
        "category": { "type": "string", "enum": ["game", "private_server"], "description": "Category of the entry." },
        "userId": { "type": "string", "description": "The ID of the user who saved this entry." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the entry was created." }
      },
      "required": ["name", "link", "category", "userId", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Storage for user profile data."
    },
    "/games/{gameId}": {
      "schema": "GameEntry",
      "description": "Storage for saved games and private server links."
    }
  }
}
